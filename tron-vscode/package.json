{
  "name": "tron-vscode",
  "publisher": "tron-team",
  "displayName": "tron-vscode",
  "description": "T.R.O.N. Developer Workflow Integration",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tron-sidebar",
          "title": "T.R.O.N.",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "tron-sidebar": [
        {
          "id": "tron-tickets",
          "name": "Active Tasks",
          "icon": "$(tasklist)"
        }
      ]
    },
    "commands": [
      {
        "command": "tron.startTaskFromTree",
        "title": "Start Task"
      },
      {
        "command": "tron.refreshTickets",
        "title": "Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "tron.createTaskOnly",
        "title": "Add Task",
        "icon": "$(add)"
      },
      {
        "command": "tron.viewAIReview",
        "title": "View AI Code Review",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tron.createTaskOnly",
          "when": "view == tron-tickets",
          "group": "navigation@1"
        },
        {
          "command": "tron.refreshTickets",
          "when": "view == tron-tickets",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "tron.viewAIReview",
          "when": "view == tron-tickets",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.15.0"
  }
}
